# ===== LLM (OpenAI-compatible endpoint, 以 OAuth client_credentials 認證) =====
LLM_URL=https://genai-api-production.dell.com/v1
LLM_MODEL=gpt-oss-120b
LLM_CLIENT_ID=your-client-id
LLM_SECRET=your-client-secret
LLM_MAX_RESPONSE_TOKENS=2048

# ===== TLS (選填) — 若公司要求自訂 CA 憑證檔，填入 .pem 路徑；留空則不驗證 =====
PEM_LOCATION=

# ===== Agent 行為 =====
# Agent 最大迭代次數 (防止無限迴圈)
MAX_ITERATIONS=10

# 是否要求模型進行 reasoning (對應 gpt-oss 的 reasoning_effort)
ENABLE_THINKING=true

# 推理強度：low / medium / high
REASONING_EFFORT=medium
